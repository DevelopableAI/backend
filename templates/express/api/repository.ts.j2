import { prisma } from '../lib/prisma.js';
import { PaginationParams } from '../lib/pagination.js';
import { {{ entity.name }}CreateInput, {{ entity.name }}UpdateInput } from '../types/{{ entity.name_lower }}.types.js';
{% set sensitive_fields = entity.fields | selectattr('is_sensitive') | list %}
{% if sensitive_fields %}
import { hashValue } from '../lib/crypto.js';
{% endif %}

{% set has_safe_select = sensitive_fields | length > 0 %}

export class {{ entity.name }}Repository {
{% if has_safe_select %}
  // Sensitive fields are excluded from all read responses
  private readonly safeSelect = {
{% for field in entity.fields if not field.is_relation %}
    {{ field.name }}: {{ 'false' if field.is_sensitive else 'true' }},
{% endfor %}
  } as const;

{% endif %}
  async findMany(
    pagination: PaginationParams,
  ): Promise<{ data: any[]; total: number }> {
    const [data, total] = await prisma.$transaction([
      prisma.{{ entity.name_lower }}.findMany({
        skip: pagination.skip,
        take: pagination.limit,
        orderBy: { {% set id_field = entity.fields | selectattr('is_id') | first %}{{ id_field.name if id_field else 'id' }}: 'desc' },
{% if has_safe_select %}
        select: this.safeSelect,
{% endif %}
      }),
      prisma.{{ entity.name_lower }}.count(),
    ]);

    return { data, total };
  }

  async findById(id: number): Promise<any | null> {
    return prisma.{{ entity.name_lower }}.findUnique({
      where: { {% set id_field = entity.fields | selectattr('is_id') | first %}{{ id_field.name if id_field else 'id' }}: id },
{% if has_safe_select %}
      select: this.safeSelect,
{% endif %}
    });
  }

  async create(data: {{ entity.name }}CreateInput): Promise<any> {
{% if sensitive_fields %}
    // Hash sensitive fields before persisting to the database
    const securedData: Record<string, any> = { ...data };
{% for field in sensitive_fields %}
    if (securedData.{{ field.name }}) {
      securedData.{{ field.name }} = await hashValue(String(securedData.{{ field.name }}));
    }
{% endfor %}
    return prisma.{{ entity.name_lower }}.create({
      // Cast to any: custom type name clashes with Prisma's checked variant; scalar FKs resolve correctly at runtime.
      data: securedData as any,
{% if has_safe_select %}
      select: this.safeSelect,
{% endif %}
    });
{% else %}
    return prisma.{{ entity.name_lower }}.create({
      // Cast to any: custom type name clashes with Prisma's checked variant; scalar FKs resolve correctly at runtime.
      data: data as any,
{% if has_safe_select %}
      select: this.safeSelect,
{% endif %}
    });
{% endif %}
  }

  async update(id: number, data: {{ entity.name }}UpdateInput): Promise<any | null> {
    try {
{% if sensitive_fields %}
      // Hash sensitive fields if included in the update payload
      const securedData: Record<string, any> = { ...data };
{% for field in sensitive_fields %}
      if (securedData.{{ field.name }}) {
        securedData.{{ field.name }} = await hashValue(String(securedData.{{ field.name }}));
      }
{% endfor %}
      return await prisma.{{ entity.name_lower }}.update({
        where: { {% set id_field = entity.fields | selectattr('is_id') | first %}{{ id_field.name if id_field else 'id' }}: id },
        // Cast to any: see create() comment above.
        data: securedData as any,
{% if has_safe_select %}
        select: this.safeSelect,
{% endif %}
      });
{% else %}
      return await prisma.{{ entity.name_lower }}.update({
        where: { {% set id_field = entity.fields | selectattr('is_id') | first %}{{ id_field.name if id_field else 'id' }}: id },
        // Cast to any: see create() comment above.
        data: data as any,
{% if has_safe_select %}
        select: this.safeSelect,
{% endif %}
      });
{% endif %}
    } catch (err: any) {
      if (err.code === 'P2025') return null;
      throw err;
    }
  }

  async delete(id: number): Promise<boolean> {
{% set id_field = entity.fields | selectattr('is_id') | first %}
    try {
{% if child_cascade_deletes %}
      // Delete child records first to avoid FK constraint violations, then delete this entity.
      await prisma.$transaction([
{% for child in child_cascade_deletes %}
        prisma.{{ child.child_name_lower }}.deleteMany({ where: { {{ child.fk_field }}: id } }),
{% endfor %}
        prisma.{{ entity.name_lower }}.delete({ where: { {{ id_field.name if id_field else 'id' }}: id } }),
      ]);
{% else %}
      await prisma.{{ entity.name_lower }}.delete({
        where: { {{ id_field.name if id_field else 'id' }}: id },
      });
{% endif %}
      return true;
    } catch (err: any) {
      if (err.code === 'P2025') return false;
      throw err;
    }
  }
{% for rel in parent_fk_relations %}

  // Find all {{ entity.name_plural }} belonging to a parent via {{ rel.fk_field }}
  async findManyBy{{ rel.fk_field[0] | upper ~ rel.fk_field[1:] }}(
    parentId: number,
    pagination: PaginationParams,
  ): Promise<{ data: any[]; total: number }> {
    const [data, total] = await prisma.$transaction([
      prisma.{{ entity.name_lower }}.findMany({
        where: { {{ rel.fk_field }}: parentId },
        skip: pagination.skip,
        take: pagination.limit,
        orderBy: { {% set id_field = entity.fields | selectattr('is_id') | first %}{{ id_field.name if id_field else 'id' }}: 'desc' },
{% if has_safe_select %}
        select: this.safeSelect,
{% endif %}
      }),
      prisma.{{ entity.name_lower }}.count({ where: { {{ rel.fk_field }}: parentId } }),
    ]);

    return { data, total };
  }
{% endfor %}
}
