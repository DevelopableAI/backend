{% for var in env_vars %}{% if var == "DATABASE_URL" and datasource.provider == "postgresql" %}{{ var }}=postgresql://user:password@localhost:5432/mydb
{% elif var == "DATABASE_URL" and datasource.provider == "mysql" %}{{ var }}=mysql://user:password@localhost:3306/mydb
{% elif var == "DATABASE_URL" and datasource.provider == "mongodb" %}{{ var }}=mongodb://localhost:27017/mydb
{% else %}{{ var }}=your-{{ var | lower | replace("_", "-") }}-here
{% endif %}{% endfor %}PORT=3000
NODE_ENV=development
