import express from 'express';
import cors from 'cors';
import helmet from 'helmet';
import morgan from 'morgan';
{% for entity in entities %}
import { {{ entity.name_plural }}Router } from './routes/{{ entity.name_plural }}.routes.js';
{% endfor %}
import { errorHandler } from './lib/errors.js';

const app = express();

app.use(helmet());
app.use(cors());
app.use(express.json());
app.use(morgan('dev'));

{% for entity in entities %}
app.use('/api/{{ entity.name_plural }}', {{ entity.name_plural }}Router);
{% endfor %}

app.get('/health', (_req, res) => {
  res.json({ status: 'ok' });
});

app.use(errorHandler);

export default app;
