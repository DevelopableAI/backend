output "alb_dns_name" {
  description = "DNS name of the Application Load Balancer — use this as your API base URL."
  value       = aws_lb.main.dns_name
}

output "rds_endpoint" {
  description = "RDS PostgreSQL endpoint (host:port)."
  value       = aws_db_instance.main.endpoint
  sensitive   = true
}

output "ecr_repository_url" {
  description = "ECR repository URL — push your Docker image here before applying."
  value       = aws_ecr_repository.main.repository_url
}
