{% endfor %}
                   })
    ctx.assert_status(resp, 401,
                      "POST /api/{{ auth_entity.name_plural }}/{{ nested_route.relation_name }} without auth → 401",
                      auth_fail=True)

    # {{ section_num }}-2  POST with auth — {{ nested_route.fk_field }} injected from token
    nested_child_id = None
    if token1:
