"""
Section {{ section_num }} — {{ entity.name }}: filter and sort query parameters.

Tests ?sortBy, ?sortOrder, and field-filter params on:
  GET /api/{{ entity.name_plural }}
{% for nr in nested_routes %}
  GET /api/{{ entity.name_plural }}/:id/{{ nr.relation_name }}
{% endfor %}

Requires ctx.state: {{ entity.name_lower }}1_id, {{ entity.name_lower }}2_id, {{ entity.name_lower }}3_id
{% if auth_entity %}
  {{ auth_entity.name_lower }}1_id (for nested scoping)
{% endif %}
{% for nr in nested_routes %}
  {{ nr.related_entity_lower }}1_id (populated by {{ nr.related_entity_plural }} seed section)
{% endfor %}
"""

from helpers import TestContext, section


def run(ctx: TestContext) -> None:
    section("{{ section_num }} · {{ entity.name | upper }} — FILTER & SORT")

    {{ entity.name_lower }}1_id = ctx.state.get("{{ entity.name_lower }}1_id")
    base = "/api/{{ entity.name_plural }}"

    # ── Sort tests ────────────────────────────────────────────────────────────

    # {{ section_num }}-1  sortBy=id&sortOrder=asc → items ordered ascending by id
    resp = ctx.req("GET", base, params={"sortBy": "id", "sortOrder": "asc", "limit": 50})
    if ctx.assert_status(resp, 200, f"GET {base}?sortBy=id&sortOrder=asc → 200"):
        data = ctx.safe_json(resp)
        ctx.assert_paginated(data, f"{base}?sortBy=id&sortOrder=asc")
        items = data.get("data", [])
        if len(items) >= 2:
            ids = [item.get("id") for item in items if item.get("id") is not None]
            if ids == sorted(ids):
                ctx.ok("sortBy=id&sortOrder=asc: items in ascending id order")
            else:
                ctx.fail(f"sortBy=id&sortOrder=asc: expected ascending ids, got {ids[:5]}")
        else:
            ctx.ok("sortBy=id&sortOrder=asc: fewer than 2 items, order not verifiable")

    # {{ section_num }}-2  sortBy=id&sortOrder=desc → items ordered descending by id
    resp = ctx.req("GET", base, params={"sortBy": "id", "sortOrder": "desc", "limit": 50})
    if ctx.assert_status(resp, 200, f"GET {base}?sortBy=id&sortOrder=desc → 200"):
        data = ctx.safe_json(resp)
        ctx.assert_paginated(data, f"{base}?sortBy=id&sortOrder=desc")
        items = data.get("data", [])
        if len(items) >= 2:
            ids = [item.get("id") for item in items if item.get("id") is not None]
            if ids == sorted(ids, reverse=True):
                ctx.ok("sortBy=id&sortOrder=desc: items in descending id order")
            else:
                ctx.fail(f"sortBy=id&sortOrder=desc: expected descending ids, got {ids[:5]}")
        else:
            ctx.ok("sortBy=id&sortOrder=desc: fewer than 2 items, order not verifiable")

    # {{ section_num }}-3  sortBy=id with no sortOrder → defaults to ascending
    resp_asc = ctx.req("GET", base, params={"sortBy": "id", "sortOrder": "asc", "limit": 50})
    resp_def = ctx.req("GET", base, params={"sortBy": "id", "limit": 50})
    if ctx.assert_status(resp_def, 200, f"GET {base}?sortBy=id (no sortOrder) → 200"):
        ctx.assert_paginated(ctx.safe_json(resp_def), f"{base}?sortBy=id")
        items_asc = ctx.safe_json(resp_asc).get("data", []) if resp_asc.status_code == 200 else []
        items_def = ctx.safe_json(resp_def).get("data", [])
        ids_asc = [i.get("id") for i in items_asc]
        ids_def = [i.get("id") for i in items_def]
        if ids_asc and ids_def:
            if ids_def == ids_asc:
                ctx.ok("sortBy=id with no sortOrder matches explicit asc order")
            else:
                ctx.fail(f"Default sortOrder should be asc. asc={ids_asc[:3]} default={ids_def[:3]}")
        else:
            ctx.ok("Default sortOrder: no items to compare")

    # {{ section_num }}-4  Unknown sortBy field → ignored, returns 200 with valid paginated response
    resp = ctx.req("GET", base, params={"sortBy": "__nonexistent_field__"})
    if ctx.assert_status(resp, 200, f"GET {base}?sortBy=__nonexistent_field__ → 200 (ignored)"):
        ctx.assert_paginated(ctx.safe_json(resp), f"{base}?sortBy=unknown")

{% for f in sensitive_fields %}
    # {{ section_num }}-5-{{ loop.index }}  sortBy={{ f.name }} (sensitive) → ignored, returns 200
    resp = ctx.req("GET", base, params={"sortBy": "{{ f.name }}"})
    if ctx.assert_status(resp, 200, f"GET {base}?sortBy={{ f.name }} (sensitive) → 200 (ignored)"):
        ctx.assert_paginated(ctx.safe_json(resp), f"{base}?sortBy={{ f.name }}")
        ctx.ok("Sensitive field '{{ f.name }}' not accepted as sortBy (correctly ignored)")

{% endfor %}
{% for f in sortable_fields %}
{% if f.name != 'id' %}
    # {{ section_num }}-6-{{ loop.index }}  sortBy={{ f.name }}&sortOrder=asc → 200, valid response
    resp = ctx.req("GET", base, params={"sortBy": "{{ f.name }}", "sortOrder": "asc"})
    if ctx.assert_status(resp, 200, f"GET {base}?sortBy={{ f.name }}&sortOrder=asc → 200"):
        ctx.assert_paginated(ctx.safe_json(resp), f"{base}?sortBy={{ f.name }}&sortOrder=asc")
        ctx.ok("sortBy={{ f.name }}&sortOrder=asc accepted")

    resp = ctx.req("GET", base, params={"sortBy": "{{ f.name }}", "sortOrder": "desc"})
    if ctx.assert_status(resp, 200, f"GET {base}?sortBy={{ f.name }}&sortOrder=desc → 200"):
        ctx.assert_paginated(ctx.safe_json(resp), f"{base}?sortBy={{ f.name }}&sortOrder=desc")
        ctx.ok("sortBy={{ f.name }}&sortOrder=desc accepted")

{% endif %}
{% endfor %}

    # ── Filter tests ──────────────────────────────────────────────────────────

    # Baseline: unfiltered total for comparison
    _baseline = ctx.req("GET", base)
    _baseline_total = ctx.safe_json(_baseline).get("meta", {}).get("total", 0) if _baseline.status_code == 200 else 0

{% if filterable_fields %}
    # Fetch entity1 to get real field values for filter assertions
    _entity1_data = {}
    if {{ entity.name_lower }}1_id:
        _fetch = ctx.req("GET", f"{base}/{{"{"}}{{ entity.name_lower }}1_id{{"}"}}")
        if _fetch.status_code == 200:
            _entity1_data = ctx.safe_json(_fetch)

{% for f in filterable_fields %}
{% if f.ts_type == 'string' %}
    # {{ section_num }}-F-{{ loop.index }}  Filter by {{ f.name }} (string) — match seeded value
    _val_{{ f.name }} = _entity1_data.get("{{ f.name }}")
    if _val_{{ f.name }} is not None:
        resp = ctx.req("GET", base, params={"{{ f.name }}": str(_val_{{ f.name }}), "limit": 50})
        if ctx.assert_status(resp, 200, f"GET {base}?{{ f.name }}={_val_{{ f.name }}} → 200"):
            data = ctx.safe_json(resp)
            ctx.assert_paginated(data, f"{base}?{{ f.name }}=<value>")
            items = data.get("data", [])
            total = data.get("meta", {}).get("total", -1)
            # entity1 should appear in filtered results
            ids_in_result = [item.get("id") for item in items]
            if {{ entity.name_lower }}1_id in ids_in_result:
                ctx.ok(f"Filter {{ f.name }}={_val_{{ f.name }}}: entity1 found in results")
            else:
                ctx.fail(f"Filter {{ f.name }}={_val_{{ f.name }}}: entity1 missing from results (ids={ids_in_result})")
            if total <= _baseline_total:
                ctx.ok(f"Filter {{ f.name }}: filtered total ({total}) ≤ baseline ({_baseline_total})")
            else:
                ctx.fail(f"Filter {{ f.name }}: filtered total ({total}) > baseline ({_baseline_total})")
            # All returned items should match the filter value
            mismatched = [item for item in items if item.get("{{ f.name }}") != _val_{{ f.name }}]
            if not mismatched:
                ctx.ok("Filter {{ f.name }}: all returned items match filter value")
            else:
                ctx.fail(f"Filter {{ f.name }}: {len(mismatched)} items have wrong value")
    else:
        ctx.skip("Filter {{ f.name }}: entity1 data not available (seed may have failed)")

    # {{ section_num }}-F-{{ loop.index }}b  Filter by {{ f.name }} with value that matches no record
    _absent_val = "__no_{{ entity.name_lower }}_has_this_value_xyz__"
    resp = ctx.req("GET", base, params={"{{ f.name }}": _absent_val})
    if ctx.assert_status(resp, 200, f"GET {base}?{{ f.name }}=<absent> → 200"):
        total = ctx.safe_json(resp).get("meta", {}).get("total", -1)
        if total == 0:
            ctx.ok(f"Filter {{ f.name }} with absent value: total=0")
        else:
            ctx.fail(f"Filter {{ f.name }} with absent value: expected total=0, got {total}")

{% elif f.ts_type == 'boolean' %}
    # {{ section_num }}-F-{{ loop.index }}  Filter by {{ f.name }} (boolean)
    for _bool_str in ("true", "false"):
        resp = ctx.req("GET", base, params={"{{ f.name }}": _bool_str, "limit": 50})
        if ctx.assert_status(resp, 200, f"GET {base}?{{ f.name }}={_bool_str} → 200"):
            data = ctx.safe_json(resp)
            ctx.assert_paginated(data, f"{base}?{{ f.name }}={_bool_str}")
            items = data.get("data", [])
            total = data.get("meta", {}).get("total", -1)
            expected_bool = _bool_str == "true"
            mismatched = [item for item in items if item.get("{{ f.name }}") != expected_bool]
            if not mismatched:
                ctx.ok(f"Filter {{ f.name }}={_bool_str}: all {len(items)} items match")
            else:
                ctx.fail(f"Filter {{ f.name }}={_bool_str}: {len(mismatched)} items have wrong value")
            if total <= _baseline_total:
                ctx.ok(f"Filter {{ f.name }}={_bool_str}: total ({total}) ≤ baseline ({_baseline_total})")

{% elif f.ts_type == 'number' %}
    # {{ section_num }}-F-{{ loop.index }}  Filter by {{ f.name }} (number) — match seeded value
    _val_{{ f.name }} = _entity1_data.get("{{ f.name }}")
    if _val_{{ f.name }} is not None:
        resp = ctx.req("GET", base, params={"{{ f.name }}": str(_val_{{ f.name }}), "limit": 50})
        if ctx.assert_status(resp, 200, f"GET {base}?{{ f.name }}={_val_{{ f.name }}} → 200"):
            data = ctx.safe_json(resp)
            ctx.assert_paginated(data, f"{base}?{{ f.name }}=<value>")
            items = data.get("data", [])
            total = data.get("meta", {}).get("total", -1)
            ids_in_result = [item.get("id") for item in items]
            if {{ entity.name_lower }}1_id in ids_in_result:
                ctx.ok(f"Filter {{ f.name }}={_val_{{ f.name }}}: entity1 found in results")
            else:
                ctx.fail(f"Filter {{ f.name }}={_val_{{ f.name }}}: entity1 missing from results")
            if total <= _baseline_total:
                ctx.ok(f"Filter {{ f.name }}: filtered total ({total}) ≤ baseline ({_baseline_total})")
    else:
        ctx.skip("Filter {{ f.name }}: entity1 data not available")

{% endif %}
{% endfor %}

    # {{ section_num }}-FC  Filter + sort + pagination composed together
{% if filterable_fields %}
    _first_filter_field = "{{ filterable_fields[0].name }}"
    _first_filter_val = _entity1_data.get(_first_filter_field)
    if _first_filter_val is not None:
        resp = ctx.req("GET", base, params={
            _first_filter_field: str(_first_filter_val),
            "sortBy": "id",
            "sortOrder": "asc",
            "page": 1,
            "limit": 5,
        })
        if ctx.assert_status(resp, 200, f"GET {base}?filter+sort+page → 200"):
            data = ctx.safe_json(resp)
            ctx.assert_paginated(data, f"{base}?filter+sort+page")
            meta = data.get("meta", {})
            if meta.get("limit") == 5 and meta.get("page") == 1:
                ctx.ok("Filter+sort+pagination: meta correct")
            else:
                ctx.fail(f"Filter+sort+pagination: unexpected meta {meta}")
            items = data.get("data", [])
            if len(items) >= 2:
                ids = [i.get("id") for i in items if i.get("id") is not None]
                if ids == sorted(ids):
                    ctx.ok("Filter+sort+pagination: items in ascending id order")
                else:
                    ctx.fail(f"Filter+sort+pagination: expected ascending ids, got {ids}")
    else:
        ctx.skip("Filter+sort+pagination: entity1 data not available")
{% endif %}

    # {{ section_num }}-FU  Unknown filter field → ignored, returns 200
    resp = ctx.req("GET", base, params={"__nonexistent_filter__": "somevalue"})
    if ctx.assert_status(resp, 200, f"GET {base}?__nonexistent_filter__=value → 200 (ignored)"):
        ctx.assert_paginated(ctx.safe_json(resp), f"{base}?unknown_filter=value")
        ctx.ok("Unknown filter field ignored, full result set returned")

{% else %}
    ctx.skip(f"No filterable fields on {{ entity.name }} — filter tests skipped")
{% endif %}

{% for nr in nested_routes %}
    # ── Nested: GET /api/{{ entity.name_plural }}/:id/{{ nr.relation_name }} filter & sort ─────────

    _parent_id = ctx.state.get("{{ entity.name_lower }}1_id")
    _nested_base = f"/api/{{ entity.name_plural }}/{{"{"}}{{ entity.name_lower }}1_id{{"}"}}/{{ nr.relation_name }}"

    if _parent_id:
        # {{ section_num }}-N{{ loop.index }}-1  sortBy=id&sortOrder=asc on nested route
        resp = ctx.req("GET", _nested_base, params={"sortBy": "id", "sortOrder": "asc", "limit": 50})
        if ctx.assert_status(resp, 200, f"GET {_nested_base}?sortBy=id&sortOrder=asc → 200"):
            data = ctx.safe_json(resp)
            ctx.assert_paginated(data, f"{_nested_base}?sortBy=id&sortOrder=asc")
            items = data.get("data", [])
            if len(items) >= 2:
                ids = [i.get("id") for i in items if i.get("id") is not None]
                if ids == sorted(ids):
                    ctx.ok(f"Nested {{ nr.relation_name }}: sortBy=id&sortOrder=asc correct")
                else:
                    ctx.fail(f"Nested {{ nr.relation_name }}: expected ascending ids, got {ids[:5]}")
            else:
                ctx.ok(f"Nested {{ nr.relation_name }}: fewer than 2 items, order not verifiable")

        # {{ section_num }}-N{{ loop.index }}-2  sortBy=id&sortOrder=desc on nested route
        resp = ctx.req("GET", _nested_base, params={"sortBy": "id", "sortOrder": "desc", "limit": 50})
        if ctx.assert_status(resp, 200, f"GET {_nested_base}?sortBy=id&sortOrder=desc → 200"):
            data = ctx.safe_json(resp)
            ctx.assert_paginated(data, f"{_nested_base}?sortBy=id&sortOrder=desc")
            items = data.get("data", [])
            if len(items) >= 2:
                ids = [i.get("id") for i in items if i.get("id") is not None]
                if ids == sorted(ids, reverse=True):
                    ctx.ok(f"Nested {{ nr.relation_name }}: sortBy=id&sortOrder=desc correct")
                else:
                    ctx.fail(f"Nested {{ nr.relation_name }}: expected descending ids, got {ids[:5]}")
            else:
                ctx.ok(f"Nested {{ nr.relation_name }}: fewer than 2 items, order not verifiable")

        # {{ section_num }}-N{{ loop.index }}-3  sortBy=id (no sortOrder) → defaults to asc
        resp = ctx.req("GET", _nested_base, params={"sortBy": "id", "limit": 50})
        if ctx.assert_status(resp, 200, f"GET {_nested_base}?sortBy=id → 200"):
            data = ctx.safe_json(resp)
            ctx.assert_paginated(data, f"{_nested_base}?sortBy=id")
            items = data.get("data", [])
            if len(items) >= 2:
                ids = [i.get("id") for i in items if i.get("id") is not None]
                if ids == sorted(ids):
                    ctx.ok(f"Nested {{ nr.relation_name }}: default sortOrder is asc")
                else:
                    ctx.fail(f"Nested {{ nr.relation_name }}: default sortOrder not asc, got {ids[:5]}")

        # {{ section_num }}-N{{ loop.index }}-4  Unknown sortBy → ignored on nested route
        resp = ctx.req("GET", _nested_base, params={"sortBy": "__nonexistent__"})
        if ctx.assert_status(resp, 200, f"GET {_nested_base}?sortBy=__nonexistent__ → 200 (ignored)"):
            ctx.assert_paginated(ctx.safe_json(resp), f"{_nested_base}?sortBy=unknown")

{% if nr.filterable_fields %}
        # {{ section_num }}-N{{ loop.index }}-5  Filter on nested {{ nr.relation_name }}
        _child1_id = ctx.state.get("{{ nr.related_entity_lower }}1_id")
        _child1_data = {}
        if _child1_id:
            _cfetch = ctx.req("GET", f"/api/{{ nr.related_entity_plural }}/{{"{"}}{{ nr.related_entity_lower }}1_id{{"}"}}")
            if _cfetch.status_code == 200:
                _child1_data = ctx.safe_json(_cfetch)

{% for f in nr.filterable_fields %}
{% if f.ts_type == 'string' %}
        _cval_{{ f.name }} = _child1_data.get("{{ f.name }}")
        if _cval_{{ f.name }} is not None:
            resp = ctx.req("GET", _nested_base, params={"{{ f.name }}": str(_cval_{{ f.name }}), "limit": 50})
            if ctx.assert_status(resp, 200, f"GET {_nested_base}?{{ f.name }}=<val> → 200"):
                data = ctx.safe_json(resp)
                ctx.assert_paginated(data, f"{_nested_base}?{{ f.name }}=<val>")
                items = data.get("data", [])
                mismatched = [item for item in items if item.get("{{ f.name }}") != _cval_{{ f.name }}]
                if not mismatched:
                    ctx.ok(f"Nested {{ nr.relation_name }} filter {{ f.name }}: all items match")
                else:
                    ctx.fail(f"Nested {{ nr.relation_name }} filter {{ f.name }}: {len(mismatched)} items mismatch")
        else:
            ctx.skip("Nested filter {{ f.name }}: child data not available")

{% elif f.ts_type == 'boolean' %}
        for _nbool in ("true", "false"):
            resp = ctx.req("GET", _nested_base, params={"{{ f.name }}": _nbool, "limit": 50})
            if ctx.assert_status(resp, 200, f"GET {_nested_base}?{{ f.name }}={_nbool} → 200"):
                items = ctx.safe_json(resp).get("data", [])
                expected = _nbool == "true"
                bad = [item for item in items if item.get("{{ f.name }}") != expected]
                if not bad:
                    ctx.ok(f"Nested {{ nr.relation_name }} filter {{ f.name }}={_nbool}: all items match")
                else:
                    ctx.fail(f"Nested {{ nr.relation_name }} filter {{ f.name }}={_nbool}: {len(bad)} mismatch")

{% endif %}
{% endfor %}
{% endif %}

        # {{ section_num }}-N{{ loop.index }}-6  Unknown filter on nested → ignored
        resp = ctx.req("GET", _nested_base, params={"__nonexistent_filter__": "val"})
        if ctx.assert_status(resp, 200, f"GET {_nested_base}?unknown_filter → 200 (ignored)"):
            ctx.assert_paginated(ctx.safe_json(resp), f"{_nested_base}?unknown_filter")

    else:
        ctx.skip(f"Nested {{ nr.relation_name }} filter/sort: {{ entity.name_lower }}1_id not available")

{% endfor %}
