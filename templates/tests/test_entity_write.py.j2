"""
Section {{ section_num }} — {{ entity.name }}: authenticated write operations (PUT / DELETE).

Requires ctx.state:
{% if auth_entity %}
  {{ auth_entity.name_lower }}1_id, {{ auth_entity.name_lower }}1_token, {{ auth_entity.name_lower }}2_token
{% endif %}
  {{ entity.name_lower }}1_id, {{ entity.name_lower }}2_id, {{ entity.name_lower }}3_id (from seed section)
"""

from helpers import TestContext, section


def run(ctx: TestContext) -> None:
    section("{{ section_num }} · {{ entity.name | upper }} — WRITE OPERATIONS")

{% if auth_entity %}
    {{ auth_entity.name_lower }}1_id = ctx.state.get("{{ auth_entity.name_lower }}1_id")
    {{ auth_entity.name_lower }}2_id = ctx.state.get("{{ auth_entity.name_lower }}2_id")
    token1 = ctx.state.get("{{ auth_entity.name_lower }}1_token")
    token2 = ctx.state.get("{{ auth_entity.name_lower }}2_token")
{% endif %}
    {{ entity.name_lower }}1_id = ctx.state.get("{{ entity.name_lower }}1_id")
    {{ entity.name_lower }}2_id = ctx.state.get("{{ entity.name_lower }}2_id")
    {{ entity.name_lower }}3_id = ctx.state.get("{{ entity.name_lower }}3_id")
{% if primary_parent_entity and primary_parent_entity.name != (auth_entity.name if auth_entity else '') %}
    {{ primary_parent_entity.name_lower }}1_id = ctx.state.get("{{ primary_parent_entity.name_lower }}1_id")
    _create_path = f"{{ canonical_create_path | replace(':id', '{' ~ primary_parent_entity.name_lower ~ '1_id}') }}"
{% else %}
    _create_path = "{{ canonical_create_path }}"
{% endif %}
{% for sfk in secondary_fk_fields %}
    {{ sfk.related_entity_lower }}1_id = ctx.state.get("{{ sfk.state_key }}")
{% endfor %}

    # {{ section_num }}-1  POST (canonical create path) without auth → 401
{% if auth_entity %}
    resp = ctx.req("POST", _create_path, body={
{% for f in required_scalar_fields %}
        "{{ f.name }}": "Anon Test",
{% endfor %}
    })
    ctx.assert_status(resp, 401,
                      "POST {{ canonical_create_path }} without auth → 401",
                      auth_fail=True)
{% endif %}

{% if auth_entity and required_scalar_fields %}
    # {{ section_num }}-2  POST with auth, empty body → 400
    if token1:
        resp = ctx.req("POST", _create_path, token=token1, body={})
        ctx.assert_status(resp, 400, "POST {{ canonical_create_path }} empty body → 400")
{% endif %}

/* LLM_SECTION_START */
# Generate required-field validation tests for entity "{{ entity.name }}".
# Canonical create path: {{ canonical_create_path }}
# Requires authentication: {{ requires_auth }}
#
# Required scalar fields (excluding server-injected FK fields):
{% for f in required_scalar_fields %}
#   {{ f.name }}: {{ f.ts_type }} (required)
{% endfor %}
#
# If the required fields list above is EMPTY, output only this single comment line and nothing else:
#   # (no required fields to validate)
#
# Otherwise, for EACH required field, generate one test:
#   - Omit only that field from the body
#   - Include all other required fields with sensible values
#   - MUST also include every secondary FK listed below in the body (they are required by the API)
#   - Expect HTTP 400: ctx.assert_status(resp, 400, "POST {{ entity.name_lower }} missing <field> → 400")
#   - Wrap in `if token1:` guard
#
{% if secondary_fk_fields %}
# Secondary FK fields — MUST appear in every request body (NOT server-injected; test must supply them):
{% for sfk in secondary_fk_fields %}
#   "{{ sfk.fk_field }}": {{ sfk.related_entity_lower }}1_id  ← variable already declared above
{% endfor %}
#
{% endif %}
# Then generate ONE ownership spoofing test for the owner FK (if present):
{% if owner_fk_field %}
#   - Include "{{ owner_fk_field }}": <user2_id> in the body while using token1
#   - If response is 201 and data.get("{{ owner_fk_field }}") == {{ auth_entity.name_lower }}1_id: ctx.ok("spoofing prevented")
#   - If response is 201 and data.get("{{ owner_fk_field }}") == {{ auth_entity.name_lower }}2_id: ctx.warn("SECURITY: ownership spoofing succeeded")
#   - Store the created entity id in ctx.state["spoofed_{{ entity.name_lower }}_id"] for cleanup
{% endif %}
#
# Available variables (already declared above):
#   token1, token2
{% if auth_entity %}
#   {{ auth_entity.name_lower }}1_id, {{ auth_entity.name_lower }}2_id
{% endif %}
#   {{ entity.name_lower }}1_id, {{ entity.name_lower }}2_id, {{ entity.name_lower }}3_id
{% for sfk in secondary_fk_fields %}
#   {{ sfk.related_entity_lower }}1_id
{% endfor %}
/* LLM_SECTION_END */

{#- Field selection priority for the PUT happy-path update:
    1. Required string (non-enum) — safest free-form value
    2. Required number — always accepts a plain integer
    3. Required enum — use first known valid enum value
    4. Optional string / number / enum (same priority order)
   This avoids accidentally using a field whose LLM-generated Zod validator
   enforces enum or other constraints that the template doesn't know about. -#}
{#- Field names the validation LLM will infer as enums (per validation_logic.txt heuristics),
    mapped to a safe value that would pass the inferred z.enum([...]) constraint. -#}
{% set _enum_like_defaults = {
    'role': 'admin',
    'type': 'standard',
    'status': 'pending',
    'category': 'general',
    'state': 'active',
    'kind': 'standard',
    'mode': 'normal',
    'tier': 'basic',
    'level': 'beginner',
    'priority': 'medium'
} %}
{% set _req_str  = required_scalar_fields | selectattr("ts_type", "equalto", "string") | rejectattr("is_enum", "equalto", true) | list %}
{% set _req_num  = required_scalar_fields | selectattr("ts_type", "equalto", "number") | list %}
{% set _req_enum = required_scalar_fields | selectattr("is_enum",  "equalto", true)    | list %}
{% set _opt_str  = optional_scalar_fields | selectattr("ts_type", "equalto", "string") | rejectattr("is_enum", "equalto", true) | list %}
{% set _opt_num  = optional_scalar_fields | selectattr("ts_type", "equalto", "number") | list %}
{% set _opt_enum = optional_scalar_fields | selectattr("is_enum",  "equalto", true)    | list %}
{% set _ranked   = _req_str + _req_num + _req_enum + _opt_str + _opt_num + _opt_enum %}
{% set _update_field = _ranked[0] if _ranked else None %}
{% if _update_field %}
    # {{ section_num }}-update  PUT happy path → 200
    if {{ entity.name_lower }}1_id and token1:
{% if _update_field.is_enum %}
        _update_val: str | int = "{{ _update_field.enum_values[0] }}"
{% elif _update_field.name in _enum_like_defaults %}
        _update_val: str | int = "{{ _enum_like_defaults[_update_field.name] }}"
{% elif 'slug' in _update_field.name.lower() %}
        _update_val: str | int = "updated-{{ entity.name_lower }}"
{% elif 'username' in _update_field.name.lower() or 'handle' in _update_field.name.lower() %}
        _update_val: str | int = "updated_{{ entity.name_lower }}"
{% elif _update_field.ts_type == "string" %}
        _update_val: str | int = "Updated {{ entity.name }}"
{% else %}
        _update_val: str | int = 42
{% endif %}
        resp = ctx.req("PUT", "/api/{{ entity.name_plural }}/" + str({{ entity.name_lower }}1_id),
                       token=token1,
                       body={"{{ _update_field.name }}": _update_val})
        if ctx.assert_status(resp, 200,
                             f"PUT /api/{{ entity.name_plural }}/{{"{"}}{{ entity.name_lower }}1_id{{"}"}} by owner → 200"):
            data = ctx.safe_json(resp)
            if data.get("{{ _update_field.name }}") == _update_val:
                ctx.ok("Updated '{{ _update_field.name }}' returned correctly")
            else:
                ctx.fail("Updated '{{ _update_field.name }}' mismatch in response")
    else:
        ctx.skip("PUT /api/{{ entity.name_plural }}/:id by owner — seed ID or token not available")
{% else %}
    # {{ section_num }}-update  No updatable scalar fields — skipping happy-path PUT test
{% endif %}

    # {{ section_num }}-auth  PUT without auth → 401
    if {{ entity.name_lower }}1_id:
        resp = ctx.req("PUT", "/api/{{ entity.name_plural }}/" + str({{ entity.name_lower }}1_id),
                       body={"title": "Anon edit attempt"})
        ctx.assert_status(resp, 401,
                          f"PUT /api/{{ entity.name_plural }}/{{"{"}}{{ entity.name_lower }}1_id{{"}"}} without auth → 401",
                          auth_fail=True)
    else:
        ctx.skip("PUT /api/{{ entity.name_plural }}/:id without auth — seed ID not available")

{% if owner_fk_field %}
    # {{ section_num }}-owner  PUT by non-owner → 403
    if {{ entity.name_lower }}1_id and token2:
        resp = ctx.req("PUT", "/api/{{ entity.name_plural }}/" + str({{ entity.name_lower }}1_id),
                       token=token2,
                       body={"title": "Hijack attempt"})
        ctx.assert_status(resp, 403,
                          f"PUT /api/{{ entity.name_plural }}/{{"{"}}{{ entity.name_lower }}1_id{{"}"}} by non-owner → 403",
                          auth_fail=True)
    else:
        ctx.skip("PUT /api/{{ entity.name_plural }}/:id by non-owner — seed ID or token2 not available")
{% endif %}

    # {{ section_num }}-notfound  PUT non-existent → 404
{% if auth_entity %}
    if token1:
        resp = ctx.req("PUT", "/api/{{ entity.name_plural }}/9999999", token=token1,
                       body={"title": "Ghost update"})
        ctx.assert_status(resp, 404, "PUT /api/{{ entity.name_plural }}/9999999 (non-existent) → 404")
    else:
        ctx.skip("PUT /api/{{ entity.name_plural }}/9999999 — token not available")
{% endif %}

    # {{ section_num }}-delete-noauth  DELETE without auth → 401
    if {{ entity.name_lower }}2_id:
        resp = ctx.req("DELETE", "/api/{{ entity.name_plural }}/" + str({{ entity.name_lower }}2_id))
        ctx.assert_status(resp, 401,
                          f"DELETE /api/{{ entity.name_plural }}/{{"{"}}{{ entity.name_lower }}2_id{{"}"}} without auth → 401",
                          auth_fail=True)
    else:
        ctx.skip("DELETE /api/{{ entity.name_plural }}/:id without auth — seed ID2 not available")

{% if owner_fk_field %}
    # {{ section_num }}-delete-nonowner  DELETE by non-owner → 403
    if {{ entity.name_lower }}2_id and token2:
        resp = ctx.req("DELETE", "/api/{{ entity.name_plural }}/" + str({{ entity.name_lower }}2_id),
                       token=token2)
        ctx.assert_status(resp, 403,
                          f"DELETE /api/{{ entity.name_plural }}/{{"{"}}{{ entity.name_lower }}2_id{{"}"}} by non-owner → 403",
                          auth_fail=True)
    else:
        ctx.skip("DELETE /api/{{ entity.name_plural }}/:id by non-owner — seed ID2 or token2 not available")
{% endif %}

    # {{ section_num }}-delete-owner  DELETE by owner → 204
{% if auth_entity %}
    if {{ entity.name_lower }}2_id and token1:
        resp = ctx.req("DELETE", "/api/{{ entity.name_plural }}/" + str({{ entity.name_lower }}2_id), token=token1)
        if ctx.assert_status(resp, 204, f"DELETE /api/{{ entity.name_plural }}/{{"{"}}{{ entity.name_lower }}2_id{{"}"}} by owner → 204"):
            ctx.state["{{ entity.name_lower }}2_deleted"] = True
    else:
        ctx.skip("DELETE /api/{{ entity.name_plural }}/:id by owner — seed ID2 or token not available")

    # {{ section_num }}-get-deleted  GET after delete → 404
    if {{ entity.name_lower }}2_id and ctx.state.get("{{ entity.name_lower }}2_deleted"):
        resp = ctx.req("GET", "/api/{{ entity.name_plural }}/" + str({{ entity.name_lower }}2_id))
        ctx.assert_status(resp, 404,
                          f"GET /api/{{ entity.name_plural }}/{{"{"}}{{ entity.name_lower }}2_id{{"}"}} after deletion → 404")

    # {{ section_num }}-delete-notfound  DELETE non-existent → 404
    if token1:
        resp = ctx.req("DELETE", "/api/{{ entity.name_plural }}/9999999", token=token1)
        ctx.assert_status(resp, 404, "DELETE /api/{{ entity.name_plural }}/9999999 (non-existent) → 404")
    else:
        ctx.skip("DELETE /api/{{ entity.name_plural }}/9999999 — token not available")
{% endif %}
